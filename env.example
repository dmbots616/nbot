# Get your token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs that have bot-admin privileges
ADMIN_IDS=123456789,987654321

# Max warnings before a user is auto-banned (default: 3)
MAX_WARNINGS=3

# Comma-separated words to auto-delete and warn for (leave blank to disable)
BANNED_WORDS=spam,scam

# MongoDB connection string
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://username:password@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017

# MongoDB database name (created automatically)
MONGO_DB_NAME=telegram_bot
